root = true

[*]
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,inl,idl,def,sln,vcxproj,vcxproj.filters,props,targets,txt,ini}]
charset = utf-8
end_of_line = crlf
indent_style = tab
tab_width = 4

[*.{rc,rc2}]
charset = utf-8
end_of_line = crlf
indent_style = tab
tab_width = 4

[*.{md,yml,yaml,json,toml}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2

[*.ps1]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 2

[*.py]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
